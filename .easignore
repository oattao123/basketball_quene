# Ignore unnecessary files for EAS Build
node_modules/
.git/
.expo/
.expo-shared/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore Python/ML folders
learn_trad/
learntrad/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Ignore large files
*.zip
*.tar.gz
*.rar
*.dmg
*.iso

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Ignore Android/iOS build folders (will be regenerated)
android/build/
android/.gradle/
ios/build/
ios/Pods/

# Ignore test files
__tests__/
*.test.js
*.spec.js
